# Ollama (Part C / D / E / Streamlit)
OLLAMA_MODEL=llama3
OLLAMA_HOST=http://127.0.0.1:11434
# Ollama Cloud (https://ollama.com/api) — Bearer auth; cloud model names differ from local (see ollama.com).
# OLLAMA_HOST=https://ollama.com
# OLLAMA_API_KEY=
# OLLAMA_MODEL=gpt-oss:120b-cloud

# Part A inputs — paths relative to repository root or absolute paths
PDF_PATH=2025-Budget-Statement-and-Economic-Policy_v4.pdf
CSV_PATH=Ghana_Election_Result.csv

# Part D — cross-encoder rerank (sentence-transformers; first run downloads weights)
CROSS_ENCODER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
